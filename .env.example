# Server
CADDY_HTTP=9090
CADDY_HTTPS=8433
BACKEND_PORT=9091
BASE_URL=https://briefcast.yourdomain.com

# Database
DATABASE_PATH=./data/briefcast.db

# Audio temp storage
AUDIO_TMP_DIR=./data/audio

# Session signing
SESSION_SECRET=change-me-to-a-random-32-character-string

# OAuth — Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth — GitHub
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# OAuth — Yandex
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=

# Groq
GROQ_API_KEY=

# Resend (email)
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@yourdomain.com

# Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=
